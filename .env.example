DISCORD_TOKEN=DISCORD_TOKEN
GEMINI_API_KEY=GEMINI_API_KEY
# Node.js Puter bot.
# Optional. If omitted, bot.js opens a browser Puter login and stores the token
# locally in node_puter_token.json.
# PUTER_AUTH_TOKEN=your_puter_auth_token
# PUTER_CHAT_MODEL=gemini-3-flash-preview
# PUTER_AI_TIMEOUT_MS=90000
# PUTER_STT_MODEL=gpt-4o-mini-transcribe
# Optional comma-separated fallback list for Puter STT provider errors.
# PUTER_STT_MODELS=gpt-4o-mini-transcribe,whisper-1
# PUTER_TTS_PROVIDER=openai
# PUTER_TTS_MODEL=gpt-4o-mini-tts
# PUTER_TTS_VOICE=nova
# Node.js Google Drive integration stores tokens in node_google_tokens.json.
# Optional: set this to sync commands to one guild instantly while developing.
# DISCORD_GUILD_ID=123456789012345678

# Optional Google Drive integration.
# Create an OAuth 2.0 Web client in Google Cloud and add this redirect URI:
# http://localhost:8080/oauth2callback
# For other Discord users to authenticate from their own devices, use a public HTTPS URL
# such as ngrok and register https://your-domain.ngrok-free.app/oauth2callback.
# GOOGLE_CLIENT_ID=your_google_oauth_client_id
# GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
# GOOGLE_PUBLIC_BASE_URL=https://your-domain.ngrok-free.app
# GOOGLE_REDIRECT_URI=http://localhost:8080/oauth2callback
# GOOGLE_OAUTH_HOST=0.0.0.0
# GOOGLE_OAUTH_PORT=8080
# GOOGLE_DRIVE_FOLDER_NAME=DisCoder

# Optional talk-coding voice mode.
# Enable MESSAGE CONTENT INTENT in the Discord Developer Portal.
# FFmpeg must be installed and available on PATH for voice playback.
# VC speech recognition requires an Opus decoder. Run npm.cmd install after
# package.json changes so opusscript is installed.
# Set false if Discord voice receive causes 4006 handshake failures; text/TTS mode still works.
# TALK_CODING_ENABLE_VOICE_RECEIVE=true
# STT mode: node_bridge uses discord.js/@discordjs/voice, vc_receive uses Python, voice_message uses attachments.
# TALK_CODING_STT_MODE=node_bridge
# STT provider for the Node bot. Use local_whisper to avoid Puter/OpenAI STT API calls.
# TALK_CODING_STT_PROVIDER=puter
# LOCAL_WHISPER_MODEL=base
# LOCAL_WHISPER_DEVICE=cpu
# LOCAL_WHISPER_COMPUTE_TYPE=int8
# LOCAL_WHISPER_PYTHON=python3
# Print recognized STT text to the session text channel for wake-word debugging.
# TALK_CODING_DEBUG_STT=false
# Optional legacy scan subscription. Leave false to record only on Discord speaking events.
# TALK_CODING_STT_SCAN_SUBSCRIBE=false
# DAVE can briefly emit undecryptable packets during MLS transitions. Raise this if receive streams close with DecryptionFailed.
# DISCORD_VOICE_DECRYPTION_FAILURE_TOLERANCE=250
# Optional comma-separated Discord user IDs. Leave empty to receive all users in the VC.
# TALK_CODING_RECEIVE_USER_IDS=123456789012345678,234567890123456789
# Same filter for voice_bridge_node.js.
# VOICE_BRIDGE_RECEIVE_USER_IDS=123456789012345678,234567890123456789
# Silence length used to split VC speech into STT chunks.
# TALK_CODING_STT_END_SILENCE_MS=800
# Save STT audio chunks as WAV files in the temp directory for debugging.
# TALK_CODING_SAVE_STT_AUDIO=false
# TALK_CODING_TTS_API_KEY=your_tts_api_key
# TALK_CODING_TTS_API_URL=https://your-tts-endpoint.example/v1/generation
# TALK_CODING_TTS_MODEL=qwen-tts-vd-bailian-voice-20260510153132574-62fc
# Alibaba Cloud DashScope API key for qwen3_tts_flash.py and optional TTS usage.
# DASHSCOPE_API_KEY=your_dashscope_api_key
# Optional: set this if your DashScope region requires a specific websocket endpoint.
# DASHSCOPE_BASE_WEBSOCKET_API_URL=wss://dashscope-intl.aliyuncs.com/api-ws/v1/inference
# Optional talk-coding STT via Google Cloud Speech-to-Text.
# Set GOOGLE_APPLICATION_CREDENTIALS to a service-account JSON path, or use Application Default Credentials.
# GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\gcp-service-account.json
# TALK_CODING_STT_LANGUAGE_CODE=ja-JP
# Optional Speech-to-Text model, for example latest_short.
# TALK_CODING_STT_MODEL=latest_short
